{
    "name": "brix-mobile",
    "version": "1.0.0",
    "packageManager": "pnpm@10.24.0",
    "main": "expo-router/entry",
    "scripts": {
        "start": "expo start",
        "start:clear": "expo start -c",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "web": "expo start --web",
        "prebuild": "expo prebuild",
        "prebuild:clean": "expo prebuild --clean",
        "prebuild:android": "expo prebuild --platform android",
        "prebuild:ios": "expo prebuild --platform ios",
        "build:dev": "eas build --profile development",
        "build:preview": "eas build --profile preview",
        "build:prod": "eas build --profile production",
        "build:android:dev": "eas build --platform android --profile development",
        "build:android:preview": "eas build --platform android --profile preview",
        "build:android:prod": "eas build --platform android --profile production",
        "build:ios:dev": "eas build --platform ios --profile development",
        "build:ios:preview": "eas build --platform ios --profile preview",
        "build:ios:prod": "eas build --platform ios --profile production",
        "build:local": "eas build --platform android --profile development --local",
        "submit:android": "eas submit --platform android",
        "submit:ios": "eas submit --platform ios",
        "update": "eas update",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
        "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
        "typecheck": "tsc --noEmit",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{json,md,yml,yaml}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@expo-google-fonts/outfit": "^0.4.3",
        "@expo-google-fonts/poppins": "^0.4.1",
        "@gorhom/bottom-sheet": "^5.2.8",
        "@hookform/resolvers": "^5.2.2",
        "@react-native-community/slider": "5.0.1",
        "@react-native-google-signin/google-signin": "^16.1.1",
        "@tanstack/react-query": "^5.90.16",
        "axios": "^1.13.2",
        "expo": "~54.0.31",
        "expo-av": "^16.0.8",
        "expo-clipboard": "^8.0.8",
        "expo-constants": "^18.0.13",
        "expo-font": "~14.0.10",
        "expo-image-picker": "^17.0.10",
        "expo-linear-gradient": "^15.0.8",
        "expo-linking": "^8.0.11",
        "expo-router": "^6.0.21",
        "expo-screen-orientation": "~9.0.8",
        "expo-splash-screen": "~31.0.13",
        "expo-status-bar": "~3.0.9",
        "expo-system-ui": "~6.0.9",
        "expo-video": "^3.0.15",
        "expo-video-player": "^2.2.0",
        "lucide-react-native": "^0.562.0",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-hook-form": "^7.70.0",
        "react-native": "0.81.5",
        "react-native-gesture-handler": "~2.28.0",
        "react-native-keyboard-controller": "1.18.5",
        "react-native-mmkv": "^4.1.1",
        "react-native-nitro-modules": "^0.32.1",
        "react-native-reanimated": "~4.1.1",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.16.0",
        "react-native-svg": "15.12.1",
        "react-native-toast-message": "^2.3.3",
        "react-native-worklets": "0.5.1",
        "socket.io-client": "^4.8.3",
        "tailwindcss": "^4.2.2",
        "uniwind": "^1.6.0",
        "zod": "^4.3.5",
        "zustand": "^5.0.9"
    },
    "private": true,
    "devDependencies": {
        "@commitlint/cli": "^20.3.1",
        "@commitlint/config-conventional": "^20.3.1",
        "@eslint/js": "^9.39.2",
        "@types/react": "~19.1.10",
        "@types/react-native": "^0.72.8",
        "babel-plugin-module-resolver": "^5.0.2",
        "babel-preset-expo": "^54.0.9",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-expo": "^1.0.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-native": "^5.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.53.0"
    }
}
